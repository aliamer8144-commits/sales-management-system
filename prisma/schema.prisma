// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./db/local.db"
}

// المستخدمين
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user") // "admin" or "user"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // العلاقات
  invoices  Invoice[]
}

// المنتجات
model Product {
  id            String   @id @default(cuid())
  name          String
  quantity      Int
  purchasePrice Float    // سعر الشراء
  alertLimit    Int      // حد التنبيه لانخفاض الكمية
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // العلاقات
  invoiceItems InvoiceItem[]
}

// العملاء
model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // العلاقات
  invoices Invoice[]
}

// الفواتير
model Invoice {
  id           String   @id @default(cuid())
  invoiceType  String   @default("cash") // "cash" or "credit"
  totalAmount  Float    @default(0)
  totalProfit  Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // العلاقات
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items      InvoiceItem[]
}

// عناصر الفاتورة
model InvoiceItem {
  id           String   @id @default(cuid())
  quantity     Int
  salePrice    Float    // سعر البيع (يدخله المستخدم)
  purchasePrice Float   // سعر الشراء (محفوظ وقت البيع)
  createdAt    DateTime @default(now())

  // العلاقات
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([productId])
}
